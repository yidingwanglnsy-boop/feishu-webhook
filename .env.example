# 飞书应用凭证（必填）
# 获取路径：飞书开放平台 → 你的应用 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 事件订阅验证（必填）
# 获取路径：飞书开放平台 → 你的应用 → 事件订阅
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# Claude Code 配置
# 默认工作目录（不设置则使用项目所在目录）
# CLAUDE_PROJECT_DIR=/home/user/projects
# Claude Code 最大执行轮次
# CLAUDE_MAX_TURNS=20

# 用户白名单（可选，留空则允许所有人）
# 多个用户用逗号分隔
# FEISHU_ALLOWED_USERS=ou_xxx,ou_yyy

# 服务端口
# FEISHU_BOT_PORT=8000

# 会话管理
# SESSION_TTL_HOURS=24
# SESSION_MAX_MESSAGES=50
